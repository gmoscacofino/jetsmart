# Copiar este archivo a terraform.tfvars y completar los valores
# NUNCA subir terraform.tfvars al repositorio (tiene credenciales)

aws_region   = "us-east-1"
project_name = "jetsmart"
environment  = "prod"

# Networking
vpc_cidr = "10.0.0.0/16"

# Lambda
lambda_timeout = 30

# Database
rds_instance_class    = "db.t3.micro"
rds_allocated_storage = 20
rds_db_name           = "jetsmart_analytics"
rds_username          = "jetsmart_admin"
rds_password          = "REEMPLAZAR_CON_PASSWORD_SEGURO"

# Secrets — obtener de Anthropic console: console.anthropic.com
anthropic_api_key = "sk-ant-REEMPLAZAR_CON_TU_API_KEY"

# Backend — debe coincidir con el suffix usado al correr 00-backend
state_bucket_suffix = "REEMPLAZAR_CON_SUFFIX_UNICO"
