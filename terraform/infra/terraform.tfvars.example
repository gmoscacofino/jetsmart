# Copiar este archivo a terraform.tfvars y completar los valores
# NUNCA subir terraform.tfvars al repositorio (tiene credenciales)

aws_region   = "us-east-1"
project_name = "jetsmart"
environment  = "prod"

# Lambda
lambda_timeout = 30

# Anthropic API key — obtener en console.anthropic.com
anthropic_api_key = "REEMPLAZAR_CON_API_KEY"

# Backend — debe coincidir con el suffix usado al correr 00-backend
state_bucket_suffix = "REEMPLAZAR_CON_SUFFIX_UNICO"

# Notifications — emails que reciben booking confirmed / failed via SNS.
# Después del apply, AWS manda un mail "Confirm subscription" a cada endpoint:
# hay que clickear el link para activar la subscription.
notification_email_subscribers = [
  # "alguien@example.com",
]
